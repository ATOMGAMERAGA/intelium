{
    "schemaVersion": 1,
    "id": "intelium",
    "version": "${version}",
    "name": "Intelium",
    "description": "Intel GPU optimization backend for Sodium. Automatically disabled on NVIDIA/AMD systems.",
    "authors": [
        "Intelium Contributors"
    ],
    "contact": {
        "homepage": "https://github.com/atomgameraga/intelium",
        "sources": "https://github.com/atomgameraga/intelium",
        "issues": "https://github.com/atomgameraga/intelium/issues"
    },
    "license": "LGPL-3.0-only",
    "icon": "assets/intelium/icon.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            "com.intelium.Intelium"
        ],
        "sodium:config_api_user": [
            "com.intelium.config.InteliumConfigEntryPoint"
        ]
    },
    "mixins": [
        {
            "config": "intelium.mixins.json",
            "environment": "client"
        }
    ],
    "depends": {
        "fabricloader": ">=0.18.0",
        "fabric-api": "*",
        "minecraft": "1.21.11",
        "java": ">=21",
        "sodium": ">=0.8.0 <0.9.0"
    }
}
